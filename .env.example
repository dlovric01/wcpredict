# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Google Sign-In Configuration
# Get these from Google Cloud Console after setting up OAuth 2.0 Client IDs
# IMPORTANT: Use the Web Application Client ID, not the iOS/Android Client IDs
GOOGLE_SERVER_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# For iOS only: Reversed iOS Client ID for URL scheme
# Example: If iOS Client ID is 123456789-abc.apps.googleusercontent.com
# Then reversed is: com.googleusercontent.apps.123456789-abc
IOS_REVERSED_CLIENT_ID=com.googleusercontent.apps.your-ios-client-id

# Note: For Apple Sign-In, configuration is done entirely through:
# 1. Apple Developer Portal (App ID with Sign In with Apple capability)
# 2. Supabase Dashboard (adding the Apple provider credentials)
# 3. iOS project configuration (entitlements are already set up)